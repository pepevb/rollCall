# LiveKit credentials — copy this to .env and fill in your values
# Get them from https://cloud.livekit.io

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Public LiveKit URL (used by the browser to connect via WebSocket)
# Must match LIVEKIT_URL
PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
